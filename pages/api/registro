import { createClient } from "@supabase/supabase-js";
const sb = createClient(process.env.SUPABASE_URL, process.env.SUPABASE_ANON_KEY);

export default async function handler(req, res) {
  if (req.method !== "POST") return res.status(405).end();
  const { nombre, email, telefono, despacho, ciudad, comunidades } = req.body;
  try {
    await sb.from("registros_trial").insert([{
      nombre, email, telefono, despacho, ciudad,
      comunidades: parseInt(comunidades) || 0,
      plan: "Profesional", trial_dias: 14,
      created_at: new Date().toISOString(),
    }]);
    res.status(200).json({ ok: true });
  } catch (e) {
    res.status(500).json({ ok: false });
  }
}
